{
  "name": "pillow-council",
  "version": "0.1.1",
  "private": false,
  "description": "CLI for running PillowCouncil's multi-agent decision board locally.",
  "license": "MIT",
  "homepage": "https://github.com/Ilbie/PillowCouncil#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ilbie/PillowCouncil.git"
  },
  "bugs": {
    "url": "https://github.com/Ilbie/PillowCouncil/issues"
  },
  "keywords": [
    "cli",
    "ai",
    "agents",
    "debate",
    "opencode",
    "nextjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "pillow-council": "bin/cli.js"
  },
  "files": [
    "bin",
    "apps/web/.next/standalone",
    "apps/web/.next/static",
    "apps/web/package.json",
    "README.md"
  ],
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @pillow-council/web",
    "dev:e2e": "tsx scripts/reset-db.ts && npm run dev:e2e --workspace @pillow-council/web",
    "dev:web": "npm run dev --workspace @pillow-council/web",
    "build": "npm run build --workspace @pillow-council/web && node scripts/prepare-standalone.mjs && npm run typecheck",
    "native:rebuild": "npm rebuild better-sqlite3",
    "typecheck": "npm run typecheck --workspace @pillow-council/shared && npm run typecheck --workspace @pillow-council/agents && npm run typecheck --workspace @pillow-council/providers && npm run typecheck --workspace @pillow-council/orchestration && npm run typecheck --workspace @pillow-council/exports && npm run typecheck --workspace @pillow-council/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:inspect": "tsx scripts/inspect-db.ts",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.27",
    "better-sqlite3": "^11.9.1",
    "open": "^10.1.2",
    "opencode-ai": "^1.2.27",
    "zod-to-json-schema": "^3.25.1"
  }
}
