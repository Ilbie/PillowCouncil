{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@pillow-council/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@pillow-council/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@pillow-council/agents": [
        "../../packages/agents/src/index.ts"
      ],
      "@pillow-council/agents/preset-generation-service": [
        "../../packages/agents/src/preset-generation-service.ts"
      ],
      "@pillow-council/agents/*": [
        "../../packages/agents/src/*"
      ],
      "@pillow-council/orchestration": [
        "../../packages/orchestration/src/index.ts"
      ],
      "@pillow-council/orchestration/*": [
        "../../packages/orchestration/src/*"
      ],
      "@pillow-council/providers": [
        "../../packages/providers/src/index.ts"
      ],
      "@pillow-council/providers/*": [
        "../../packages/providers/src/*"
      ],
      "@pillow-council/exports": [
        "../../packages/exports/src/index.ts"
      ],
      "@pillow-council/exports/*": [
        "../../packages/exports/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
